<% content_for :breadcrumb do %>
  <span class="text-text-primary">Bridge</span>
<% end %>

<div class="space-y-8 max-w-6xl">
  <div>
    <div class="flex items-center gap-3">
      <span class="text-neon-blue text-3xl">⇌</span>
      <div>
        <h1 class="text-2xl font-bold text-neon-blue font-mono tracking-tight">BRIDGE</h1>
        <p class="text-text-muted text-sm mt-0.5">External integrations — link everything together</p>
      </div>
    </div>
  </div>

  <% unless @forge_available %>
    <div class="rounded-xl bg-bg-panel border border-border-faint p-8 text-center">
      <span class="text-4xl text-neon-blue/40 mb-4 block">⇌</span>
      <h2 class="text-xl font-bold text-text-primary mb-2">Forge CLI Not Detected</h2>
      <p class="text-text-muted max-w-md mx-auto">Install Forge first to check integration status.</p>
    </div>
  <% else %>
    <% connected = @integrations.count { |i| i[:available] } %>
    <% total = @integrations.count %>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <%= stat_card label: "Connected", value: "#{connected}/#{total}", icon: "⇌",
          icon_color: "text-neon-blue" %>
      <%= stat_card label: "Integrations", value: total, icon: "◈",
          icon_color: "text-neon-purple" %>
      <%= stat_card label: "Hooks", value: @hooks.count, icon: "⚡",
          icon_color: "text-neon-cyan" %>
    </div>

    <!-- Integration cards grouped by type -->
    <% groups = @integrations.group_by { |i| i[:type] } %>
    <% type_labels = { "core" => "Core", "vcs" => "Version Control", "compress" => "Compression",
                       "agent" => "AI Agents", "cli" => "CLI Tools", "search" => "Search",
                       "container" => "Containers", "cache" => "Cache", "web" => "Web Services",
                       "desktop" => "Desktop" } %>

    <% groups.each do |type, integrations| %>
      <div>
        <h3 class="text-sm font-semibold text-text-primary mb-3 uppercase tracking-wider">
          <%= type_labels[type] || type.capitalize %>
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% integrations.each do |int| %>
            <div class="rounded-xl bg-bg-panel border border-border-faint p-4
                        <%= int[:available] ? "border-neon-green/20" : "" %>">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="<%= int[:available] ? "text-neon-green" : "text-text-dim" %> text-lg">
                    <%= int[:available] ? "●" : "○" %>
                  </span>
                  <div>
                    <span class="text-sm font-semibold font-mono text-text-primary"><%= int[:name] %></span>
                    <% if int[:hint] %>
                      <p class="text-xs text-text-muted mt-0.5"><%= int[:hint] %></p>
                    <% end %>
                  </div>
                </div>
                <span class="text-xs font-mono uppercase tracking-wider px-2 py-0.5 rounded
                             <%= int[:available] ? "bg-neon-green/10 text-neon-green" : "bg-text-dim/10 text-text-dim" %>">
                  <%= int[:available] ? "connected" : "disconnected" %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Hooks section -->
    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">⚡ Lifecycle Hooks</h3>
      <% if @hooks.any? %>
        <div class="space-y-2">
          <% @hooks.each do |hook| %>
            <div class="flex items-center gap-3 py-2 px-3 rounded-lg bg-bg-surface/30 border border-border-faint">
              <span class="<%= hook[:executable] ? "text-neon-green" : "text-neon-yellow" %> text-xs">
                <%= hook[:executable] ? "●" : "○" %>
              </span>
              <code class="text-xs font-mono text-text-primary flex-1"><%= hook[:name] %></code>
              <span class="text-xs text-text-muted"><%= hook[:executable] ? "executable" : "not executable" %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6 text-text-dim">
          <p class="text-sm font-mono">No hooks configured</p>
          <p class="text-xs mt-2">Create scripts in <code class="text-neon-cyan">~/.forge/scripts/</code> to register lifecycle hooks.</p>
        </div>
      <% end %>
    </div>

    <!-- Sync Dashboard -->
    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">⇌ Sync Dashboard</h3>
      <div class="flex items-center gap-4 mb-4">
        <%= button_to "/bridge/sync", method: :get, form: { data: { turbo_stream: true } },
            class: "px-4 py-2 rounded-lg bg-neon-blue/20 text-neon-blue border border-neon-blue/30
                    font-mono text-sm hover:bg-neon-blue/30 transition-colors" do %>
          ⟳ Sync All Platforms
        <% end %>
        <span class="text-xs text-text-muted font-mono">Runs <code class="text-neon-cyan">forge bridge sync --verbose</code></span>
      </div>
      <div id="sync-output">
        <div class="py-3 px-4 rounded-lg bg-bg-surface/30 border border-border-faint">
          <div class="flex items-center gap-2">
            <span class="text-text-dim text-xs">●</span>
            <span class="text-xs text-text-muted font-mono">No sync performed yet</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Test Notification -->
    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">📨 Test Notification</h3>
      <%= form_with url: "/bridge/notify", method: :post, data: { turbo_stream: true },
          class: "space-y-3" do |f| %>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="flex-shrink-0">
            <label class="text-xs text-text-muted font-mono mb-1 block">Channel</label>
            <%= select_tag :channel,
                options_for_select([ [ "Desktop", "desktop" ], [ "Telegram", "telegram" ], [ "Discord", "discord" ] ], "desktop"),
                class: "bg-bg-surface/50 border border-border-faint rounded-lg px-3 py-2 text-sm
                        font-mono text-text-primary focus:border-neon-blue focus:outline-none" %>
          </div>
          <div class="flex-1">
            <label class="text-xs text-text-muted font-mono mb-1 block">Message</label>
            <%= text_field_tag :message, nil, placeholder: "Enter notification message...",
                class: "w-full bg-bg-surface/50 border border-border-faint rounded-lg px-3 py-2 text-sm
                        font-mono text-text-primary placeholder:text-text-dim
                        focus:border-neon-blue focus:outline-none" %>
          </div>
          <div class="flex items-end">
            <%= submit_tag "Send",
                class: "px-4 py-2 rounded-lg bg-neon-blue/20 text-neon-blue border border-neon-blue/30
                        font-mono text-sm hover:bg-neon-blue/30 transition-colors" %>
          </div>
        </div>
      <% end %>
      <div id="notification-result" class="mt-3"></div>
    </div>

    <!-- CLI commands -->
    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">Commands</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% commands = [
          { cmd: "forge bridge", desc: "Connection status dashboard" },
          { cmd: "forge bridge hooks", desc: "List webhook endpoints" },
          { cmd: "forge bridge notify -c desktop", desc: "Send desktop notification" },
          { cmd: "forge bridge notify -c telegram", desc: "Send Telegram message" },
          { cmd: "forge bridge notify -c discord", desc: "Send Discord webhook" },
          { cmd: "forge grip diagnose", desc: "System health check" }
        ] %>
        <% commands.each do |cmd| %>
          <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-faint">
            <code class="text-xs text-neon-purple font-mono"><%= cmd[:cmd] %></code>
            <p class="text-xs text-text-muted mt-1"><%= cmd[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
