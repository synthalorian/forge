<% content_for :breadcrumb do %>
  <span class="text-text-primary">Bellows</span>
<% end %>

<div class="space-y-8 max-w-6xl">
  <div>
    <div class="flex items-center gap-3">
      <span class="text-neon-purple text-3xl">◇</span>
      <div>
        <h1 class="text-2xl font-bold text-neon-purple font-mono tracking-tight">BELLOWS</h1>
        <p class="text-text-muted text-sm mt-0.5">AI agent orchestration harness</p>
      </div>
    </div>
  </div>

  <% running = @agents.count { |a| a[:status] == "running" } %>
  <% installed = @agents.count { |a| a[:status] != "not_installed" } %>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= stat_card label: "Agents Available", value: installed, icon: "◇",
        icon_color: "text-neon-purple" %>
    <%= stat_card label: "Currently Running", value: running, icon: "●",
        icon_color: "text-neon-green" %>
    <%= stat_card label: "Priority Agent",
        value: (@agents.find { |a| a[:status] == "running" } || @agents.find { |a| a[:status] != "not_installed" })&.dig(:name) || "None",
        icon: "⚡",
        icon_color: "text-neon-pink" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <% @agents.each do |agent| %>
      <div class="rounded-xl bg-bg-panel border border-border-faint p-5
                  <%= agent[:status] == "running" ? "border-neon-green/20" : "" %>">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            <% status_dot = case agent[:status]
               when "running" then "bg-neon-green animate-pulse"
               when "stopped" then "bg-neon-yellow"
               else "bg-text-dim"
               end %>
            <span class="w-2.5 h-2.5 rounded-full <%= status_dot %> shrink-0"></span>
            <span class="text-sm font-semibold font-mono text-text-primary"><%= agent[:name] %></span>
          </div>
          <span class="text-xs font-mono uppercase tracking-wider
                       <%= case agent[:status]
                           when "running" then "text-neon-green"
                           when "stopped" then "text-neon-yellow"
                           else "text-text-dim"
                           end %>">
            <%= agent[:status].tr("_", " ") %>
          </span>
        </div>
        <div class="flex items-center gap-4 text-xs text-text-muted">
          <span class="bg-bg-surface/50 px-2 py-0.5 rounded font-mono border border-border-faint"><%= agent[:type] %></span>
          <% if agent[:model] %>
            <span><%= agent[:model] %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
    <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">Commands</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% commands = [
        { cmd: "forge breathe", desc: "Agent status dashboard" },
        { cmd: "forge strike <task>", desc: "Execute task via AI" },
        { cmd: "forge breathe models", desc: "List available models" },
        { cmd: "forge breathe vault", desc: "Credential management" },
        { cmd: "forge breathe prompts", desc: "Prompt library" },
        { cmd: "forge breathe pipe", desc: "Agent pipelines" }
      ] %>
      <% commands.each do |cmd| %>
        <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-faint">
          <code class="text-xs text-neon-cyan font-mono"><%= cmd[:cmd] %></code>
          <p class="text-xs text-text-muted mt-1"><%= cmd[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
    <h3 class="text-sm font-semibold text-text-primary mb-3 uppercase tracking-wider">Agent Priority</h3>
    <div class="flex items-center gap-2 flex-wrap">
      <% priority = ["opencode", "llama-swap", "hermes", "codex"] %>
      <% priority.each_with_index do |name, i| %>
        <% if i > 0 %>
          <span class="text-text-dim text-xs">→</span>
        <% end %>
        <span class="px-3 py-1.5 rounded-lg text-xs font-mono
                     <%= i == 0 ? "bg-neon-purple/20 text-neon-purple border border-neon-purple/30" : "bg-bg-surface/50 text-text-muted border border-border-faint" %>">
          <%= i + 1 %>. <%= name %>
        </span>
      <% end %>
    </div>
    <p class="text-xs text-text-muted mt-3">Forge routes tasks to the highest-priority running agent. Local agents preferred over remote.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-neon-purple mb-4 uppercase tracking-wider font-mono">Quick Strike</h3>
      <%= form_with url: "/bellows/strike", method: :post, data: { turbo_frame: "bellows-output" }, local: true do |f| %>
        <div class="space-y-3">
          <%= f.text_field :task, placeholder: "Describe a task...",
              class: "w-full rounded-lg bg-bg-dark/80 border border-border-faint px-3 py-2
                     text-sm font-mono text-text-primary placeholder-text-dim
                     focus:border-neon-purple focus:outline-none focus:ring-1 focus:ring-neon-purple/50" %>
          <%= f.submit "Strike",
              class: "w-full rounded-lg bg-neon-purple/20 border border-neon-purple/30 px-4 py-2
                     text-sm font-mono text-neon-purple hover:bg-neon-purple/30 transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="rounded-xl bg-bg-panel border border-border-faint p-5" data-controller="pipeline-builder">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-neon-purple uppercase tracking-wider font-mono">Pipeline Builder</h3>
        <div class="flex items-center gap-2">
          <!-- Preset dropdown -->
          <select data-action="pipeline-builder#loadPreset"
                  class="rounded-lg bg-bg-dark/80 border border-border-faint px-2.5 py-1.5 text-xs font-mono text-text-muted focus:border-neon-purple focus:outline-none focus:ring-1 focus:ring-neon-purple/50 cursor-pointer">
            <option value="">Load Preset...</option>
            <option value="code_review">Code Review</option>
            <option value="research_write">Research & Write</option>
            <option value="code_gen_test">Code Gen + Test</option>
            <option value="data_pipeline">Data Pipeline</option>
          </select>
          <!-- Expand / Collapse toggle -->
          <button type="button" data-action="pipeline-builder#toggleExpand"
                  class="rounded-lg bg-bg-dark/80 border border-border-faint px-2.5 py-1.5 text-xs font-mono text-text-muted hover:text-neon-purple hover:border-neon-purple/30 transition-colors cursor-pointer"
                  title="Toggle expand/collapse">
            <span>▾ Collapse</span>
          </button>
        </div>
      </div>

      <!-- Collapsed summary (always rendered) -->
      <div data-pipeline-builder-target="collapsedInfo"
           class="mb-3 flex flex-wrap items-center gap-1.5">
        <span class="text-text-dim text-xs">No pipeline steps yet</span>
      </div>

      <!-- Expanded body -->
      <div data-pipeline-builder-target="expandedBody">
        <!-- Step cards container -->
        <div data-pipeline-builder-target="stepsContainer" class="space-y-3 mb-4">
          <div class="text-center py-6 text-text-dim border-2 border-dashed border-border-faint rounded-xl">
            <p class="text-sm font-mono">No steps defined</p>
            <p class="text-xs mt-1">Click <span class="text-neon-purple">"Add Step"</span> to begin building your pipeline</p>
          </div>
        </div>

        <!-- Hidden step template (not used in this implementation, placeholder for toml form) -->
        <%= form_with url: "/bellows/pipeline", method: :post, data: { turbo_frame: "bellows-output" }, local: true, id: "pipeline-form" do |f| %>
          <%= f.hidden_field :toml, data: { pipeline_builder_target: "hiddenToml" } %>
          <div class="flex flex-wrap items-center gap-3">
            <button type="button" data-action="pipeline-builder#addStep"
                    class="rounded-lg bg-neon-purple/20 border border-neon-purple/30 px-4 py-2 text-sm font-mono text-neon-purple hover:bg-neon-purple/30 transition-colors cursor-pointer">
              + Add Step
            </button>
            <button type="submit" data-action="pipeline-builder#submitPipeline"
                    class="rounded-lg bg-neon-green/20 border border-neon-green/30 px-4 py-2 text-sm font-mono text-neon-green hover:bg-neon-green/30 transition-colors cursor-pointer">
              ▶ Run Pipeline
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-neon-purple uppercase tracking-wider font-mono">Sessions</h3>
      <div class="flex gap-2">
        <%= button_to "Load Sessions", "/bellows/sessions", method: :get,
            form: { data: { turbo_frame: "bellows-output" } },
            class: "rounded-lg bg-bg-surface/50 border border-border-faint px-3 py-1.5
                   text-xs font-mono text-text-muted hover:text-neon-purple hover:border-neon-purple/30 transition-colors cursor-pointer" %>
      </div>
    </div>
    <p class="text-xs text-text-muted mb-4">Recent agent sessions from <code class="text-neon-purple">forge breathe sessions</code>. Click Load Sessions to fetch.</p>
  </div>

  <turbo-frame id="bellows-output">
    <div id="bellows-output" class="space-y-4">
      <div class="rounded-xl bg-bg-panel border border-border-faint p-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-neon-purple text-xs font-mono">▸</span>
          <h4 class="text-sm font-semibold text-text-primary font-mono">Output</h4>
        </div>
        <div class="text-center py-8 text-text-dim">
          <p class="text-sm font-mono">Run a strike, pipeline, or session query to see output</p>
        </div>
      </div>
    </div>
  </turbo-frame>
</div>
