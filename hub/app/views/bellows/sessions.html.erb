<% content_for :breadcrumb do %>
  <%= link_to "Bellows", "/bellows", class: "text-text-muted hover:text-neon-purple transition-colors" %>
  <span class="text-text-dim mx-2">›</span>
  <span class="text-text-primary">Sessions</span>
<% end %>

<div class="space-y-6 max-w-6xl">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-neon-purple text-2xl">◇</span>
      <div>
        <h1 class="text-2xl font-bold text-neon-purple font-mono tracking-tight">SESSIONS</h1>
        <p class="text-text-muted text-sm mt-0.5">Agent session history</p>
      </div>
    </div>
    <%= link_to "← Back to Bellows", "/bellows",
        class: "rounded-lg bg-bg-surface/50 border border-border-faint px-3 py-1.5
               text-xs font-mono text-text-muted hover:text-neon-purple hover:border-neon-purple/30 transition-colors" %>
  </div>

  <% if @sessions.any? %>
    <div class="space-y-3">
      <% @sessions.each do |session| %>
        <div class="rounded-xl bg-bg-panel border border-border-faint p-5
                    hover:border-neon-purple/30 transition-colors group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-2">
                <span class="px-2 py-0.5 rounded text-xs font-mono
                             bg-neon-purple/10 border border-neon-purple/20 text-neon-purple">
                  <%= session["agent_name"] %>
                </span>
                <span class="text-xs text-text-muted font-mono">
                  <%= session["message_count"] %> messages
                </span>
              </div>
              <h3 class="text-sm font-semibold text-text-primary font-mono truncate">
                <%= session["title"].presence || "Untitled Session" %>
              </h3>
              <div class="flex items-center gap-4 mt-2 text-xs text-text-dim font-mono">
                <span>Created: <%= session["created_at"] %></span>
                <span>Updated: <%= session["updated_at"] %></span>
              </div>
            </div>

            <div class="flex items-center gap-2 shrink-0">
              <%= link_to "View", "/bellows/sessions/#{session["id"]}",
                  class: "rounded-lg bg-neon-purple/10 border border-neon-purple/20 px-3 py-1.5
                         text-xs font-mono text-neon-purple hover:bg-neon-purple/20 transition-colors" %>
              <%= button_to "Delete", "/bellows/sessions/#{session["id"]}", method: :delete,
                  form: { class: "inline" },
                  params: { confirm: "Are you sure?" },
                  class: "rounded-lg bg-bg-surface/50 border border-border-faint px-3 py-1.5
                         text-xs font-mono text-text-dim hover:text-neon-red hover:border-neon-red/30 transition-colors cursor-pointer" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @total_pages > 1 %>
      <div class="flex items-center justify-center gap-2 pt-4">
        <% if @page > 1 %>
          <%= link_to "← Prev", "/bellows/sessions?page=#{@page - 1}",
              class: "rounded-lg bg-bg-surface/50 border border-border-faint px-3 py-1.5
                     text-xs font-mono text-text-muted hover:text-neon-purple hover:border-neon-purple/30 transition-colors" %>
        <% end %>

        <span class="text-xs text-text-dim font-mono px-3">
          Page <%= @page %> of <%= @total_pages %>
        </span>

        <% if @page < @total_pages %>
          <%= link_to "Next →", "/bellows/sessions?page=#{@page + 1}",
              class: "rounded-lg bg-bg-surface/50 border border-border-faint px-3 py-1.5
                     text-xs font-mono text-text-muted hover:text-neon-purple hover:border-neon-purple/30 transition-colors" %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-xl bg-bg-panel border border-border-faint p-12 text-center">
      <span class="text-3xl text-text-dim">◇</span>
      <p class="text-text-dim font-mono text-sm mt-4">No sessions found</p>
      <p class="text-text-dim text-xs mt-1">Agent sessions will appear here after running tasks</p>
    </div>
  <% end %>
</div>
