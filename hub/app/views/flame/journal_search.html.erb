<% content_for :breadcrumb do %>
  <%= link_to "Flame", "/flame", class: "hover:text-neon-cyan transition-colors" %>
  <span class="text-text-dim">/</span>
  <%= link_to "Journal", "/flame/journal", class: "hover:text-neon-cyan transition-colors" %>
  <span class="text-text-dim">/</span>
  <span class="text-text-primary">Search</span>
<% end %>

<% @title = "Search Results · Journal · Flame" %>

<div class="space-y-6 max-w-5xl">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-neon-cyan text-2xl">🔍</span>
      <div>
        <h1 class="text-xl font-bold text-neon-pink font-mono tracking-tight">JOURNAL SEARCH</h1>
        <p class="text-text-muted text-xs mt-0.5">
          Results for: <code class="text-neon-cyan font-mono"><%= @query %></code>
        </p>
      </div>
    </div>
    <%= link_to "← Back to Journal", "/flame/journal",
          class: "text-xs text-neon-cyan font-mono hover:text-neon-pink transition-colors" %>
  </div>

  <%# --- Search --- %>
  <div class="rounded-xl bg-bg-panel border border-neon-pink/20 p-5">
    <%= form_with url: "/flame/journal/search", method: :post, class: "flex gap-3" do |f| %>
      <%= f.text_field :query,
            value: @query,
            placeholder: "Search journal entries...",
            class: "flex-1 bg-bg-dark/80 border border-border-faint rounded-lg px-4 py-2 text-sm font-mono text-text-primary placeholder:text-text-dim focus:outline-none focus:border-neon-pink/50" %>
      <%= f.submit "Search",
            class: "bg-neon-pink/20 border border-neon-pink/40 text-neon-pink px-4 py-2 rounded-lg text-sm font-mono hover:bg-neon-pink/30 transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <div class="rounded-xl bg-bg-panel border border-neon-pink/20 p-6">
    <div class="bg-bg-dark/80 rounded-lg p-5 border border-border-faint">
      <pre class="text-sm text-neon-cyan/90 font-mono whitespace-pre-wrap leading-relaxed"><%= @search_output %></pre>
    </div>
  </div>
</div>
