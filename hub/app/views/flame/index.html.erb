<% content_for :breadcrumb do %>
  <span class="text-text-primary">Flame</span>
<% end %>

<div class="space-y-8 max-w-6xl">
  <div>
    <div class="flex items-center gap-3">
      <span class="text-neon-pink text-3xl">✦</span>
      <div>
        <h1 class="text-2xl font-bold text-neon-pink font-mono tracking-tight">FLAME</h1>
        <p class="text-text-muted text-sm mt-0.5">Scripture & spirit — the fire that tempers the steel</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= stat_card label: "Bible Verses", value: "31,103", icon: "📖",
        icon_color: "text-neon-pink" %>
    <%= stat_card label: "Translation", value: "KJV", icon: "✦",
        icon_color: "text-neon-purple" %>
    <%= stat_card label: "Journal Entries", value: @journal_count, icon: "📝",
        icon_color: "text-neon-cyan" %>
  </div>

  <div class="rounded-xl bg-bg-panel border border-neon-pink/20 p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-neon-pink text-xl">📖</span>
      <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider">Today's Verse</h3>
    </div>
    <% if @daily_verse.present? %>
      <pre class="text-sm text-neon-cyan/90 font-mono whitespace-pre-wrap leading-relaxed"><%= @daily_verse %></pre>
    <% else %>
      <p class="text-text-muted text-sm">Run <code class="text-neon-cyan font-mono">forge word</code> to see today's verse.</p>
    <% end %>
  </div>

  <%# --- Interactive Scripture Search --- %>
  <div class="rounded-xl bg-bg-panel border border-neon-pink/20 p-6" data-controller="scripture-search">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-neon-pink text-xl">🔍</span>
      <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider">Scripture Search</h3>
    </div>
    <%= form_with url: "/flame/search", method: :post, class: "flex gap-3",
          data: { scripture_search_target: "form" } do |f| %>
      <%= f.text_field :query,
            placeholder: "Search the scriptures...",
            data: { scripture_search_target: "input", action: "input->scripture-search#search" },
            class: "flex-1 bg-bg-dark/80 border border-border-faint rounded-lg px-4 py-2 text-sm font-mono text-text-primary placeholder:text-text-dim focus:outline-none focus:border-neon-pink/50" %>
      <%= f.submit "Search",
            class: "bg-neon-pink/20 border border-neon-pink/40 text-neon-pink px-4 py-2 rounded-lg text-sm font-mono hover:bg-neon-pink/30 transition-colors cursor-pointer" %>
    <% end %>
    <%= turbo_frame_tag "flame-search-results", data: { scripture_search_target: "results" } do %>
    <% end %>
  </div>

  <%# --- Reference Lookup --- %>
  <div class="rounded-xl bg-bg-panel border border-border-faint p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-neon-purple text-xl">📚</span>
      <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider">Reference Lookup</h3>
    </div>
    <%= form_with url: "/flame/reference", method: :post, class: "flex gap-3 items-end" do |f| %>
      <div class="flex-1">
        <label class="block text-xs text-text-muted font-mono mb-1">Book</label>
        <%= f.text_field :book,
              placeholder: "John",
              class: "w-full bg-bg-dark/80 border border-border-faint rounded-lg px-3 py-2 text-sm font-mono text-text-primary placeholder:text-text-dim focus:outline-none focus:border-neon-purple/50" %>
      </div>
      <div class="w-24">
        <label class="block text-xs text-text-muted font-mono mb-1">Chapter</label>
        <%= f.text_field :chapter,
              placeholder: "3",
              class: "w-full bg-bg-dark/80 border border-border-faint rounded-lg px-3 py-2 text-sm font-mono text-text-primary placeholder:text-text-dim focus:outline-none focus:border-neon-purple/50" %>
      </div>
      <div class="w-24">
        <label class="block text-xs text-text-muted font-mono mb-1">Verse</label>
        <%= f.text_field :verse,
              placeholder: "16",
              class: "w-full bg-bg-dark/80 border border-border-faint rounded-lg px-3 py-2 text-sm font-mono text-text-primary placeholder:text-text-dim focus:outline-none focus:border-neon-purple/50" %>
      </div>
      <%= f.submit "Lookup",
            class: "bg-neon-purple/20 border border-neon-purple/40 text-neon-purple px-4 py-2 rounded-lg text-sm font-mono hover:bg-neon-purple/30 transition-colors cursor-pointer" %>
    <% end %>
    <%= turbo_frame_tag "flame-reference-results" do %>
    <% end %>
  </div>

  <%# --- Recent Journal Entries --- %>
  <div class="rounded-xl bg-bg-panel border border-neon-cyan/20 p-6">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <span class="text-neon-cyan text-xl">📝</span>
        <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider">Recent Journal Entries</h3>
      </div>
      <%= link_to "View All", "/flame/journal",
            data: { turbo_stream: true },
            class: "text-xs text-neon-cyan font-mono hover:text-neon-pink transition-colors" %>
    </div>
    <%= turbo_frame_tag "flame-journal-list" do %>
      <% if @journal_entries.present? %>
        <div class="space-y-2">
          <% @journal_entries.each do |entry| %>
            <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-faint">
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs text-neon-purple font-mono">#<%= entry[:id] %></span>
                <span class="text-xs text-text-muted"><%= entry[:created_at].to_s.strftime("%b %d, %Y %H:%M") rescue entry[:created_at] %></span>
              </div>
              <p class="text-xs text-text-muted font-mono truncate"><%= entry[:content].to_s.truncate(120) %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6 text-text-dim">
          <p class="text-sm font-mono">No journal entries found</p>
          <p class="text-xs text-text-muted mt-1">Run <code class="text-neon-purple font-mono">forge reflect entry "Today I..."</code> to start</p>
        </div>
      <% end %>
    <% end %>
    <div class="mt-4 p-3 rounded-lg bg-bg-surface/30 border border-border-faint">
      <div class="flex items-center gap-2">
        <span class="text-xs text-neon-yellow">🔒</span>
        <span class="text-xs text-text-muted">AES-256-GCM encrypted at rest</span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">📖 Scripture</h3>
      <div class="space-y-2">
        <% scripture_cmds = [
          { cmd: "forge word", desc: "Today's verse" },
          { cmd: "forge word search <query>", desc: "Full-text search" },
          { cmd: "forge word reference John 3:16", desc: "Passage lookup" },
          { cmd: "forge word search \"For God so loved\"", desc: "Search by phrase" }
        ] %>
        <% scripture_cmds.each do |cmd| %>
          <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-faint">
            <code class="text-xs text-neon-cyan font-mono"><%= cmd[:cmd] %></code>
            <p class="text-xs text-text-muted mt-1"><%= cmd[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">📝 Prayer Journal</h3>
      <div class="space-y-2">
        <% journal_cmds = [
          { cmd: "forge reflect entry \"Today I...\"", desc: "Write an entry" },
          { cmd: "forge reflect history", desc: "Browse entries" },
          { cmd: "forge reflect read <id>", desc: "Read specific entry" },
          { cmd: "forge reflect search <query>", desc: "Search entries" }
        ] %>
        <% journal_cmds.each do |cmd| %>
          <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-faint">
            <code class="text-xs text-neon-purple font-mono"><%= cmd[:cmd] %></code>
            <p class="text-xs text-text-muted mt-1"><%= cmd[:desc] %></p>
          </div>
        <% end %>
      </div>
      <div class="mt-4 p-3 rounded-lg bg-bg-surface/30 border border-border-faint">
        <div class="flex items-center gap-2">
          <span class="text-xs text-neon-yellow">🔒</span>
          <span class="text-xs text-text-muted">AES-256-GCM encrypted at rest</span>
        </div>
      </div>
    </div>
  </div>

  <div class="rounded-xl bg-bg-panel border border-neon-purple/20 p-5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-neon-purple text-xl">🕯️</span>
        <div>
          <h3 class="text-sm font-semibold text-text-primary">Sabbath Mode</h3>
          <p class="text-xs text-text-muted mt-0.5">Shut down all agents and find rest</p>
        </div>
      </div>
      <code class="text-xs text-neon-cyan font-mono bg-bg-surface/50 px-3 py-1.5 rounded border border-border-faint">forge rest</code>
    </div>
  </div>
</div>
