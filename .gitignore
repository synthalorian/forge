# Build artifacts
/target/
**/*.rs.bk

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# forge data (local only)
*.tar.zst
*.db

# OMO / OpenCode artifacts
.omo/

# ===========================================
# Forge Hub (Rails)
# ===========================================

# Rails artifacts
hub/log/*
hub/tmp/*
hub/storage/*

# Asset builds (regenerated by tailwindcss:build)
hub/app/assets/builds/tailwind.css

# Bundler
hub/vendor/bundle/

# Ruby version managers
hub/.ruby-version
hub/.rbenv-vars

# Database
hub/db/*.sqlite3
hub/db/*.sqlite3-*

# Credentials
hub/config/master.key
hub/config/credentials/*.key

# Test coverage
hub/coverage/

# Node (if added later)
hub/node_modules/

# Ignore generated tailwind build — rebuild with: cd hub && bundle exec rails tailwindcss:build
